# Backend .env.example — copy to backend/.env and fill in real values.
# Never commit a .env file with real secrets.

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Claude model (change here AND in CLAUDE.md if you ever upgrade)
# ---------------------------------------------------------------------------
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Supabase (not connected yet — add these when wiring up the DB layer)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# CORS allowed origins (comma-separated)
# ---------------------------------------------------------------------------
# ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:5173
